cat > .dockerignore <<'EOF'
.git
.github
.gitignore

.env
.env.*
!.env.example

.venv
.venv/
.venv-1
.venv-1/
venv
venv/

__pycache__
**/__pycache__
*.pyc
*.pyo
*.pyd

.pytest_cache
.mypy_cache
.ruff_cache

data/raw
data/processed
data/vector_store
data/evidence
data/observability/*.json
data/evaluation/*results*.json
data/evaluation/*report*.md
data/evaluation/*summary*.csv

reports/*.pdf
reports/*.pdf.not_generated.txt

*.parquet
*.csv
*.log

.vscode
.idea

docker/environments/production.env

bash_commands.txt
EOF