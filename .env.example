# ============================================================
# Digital Forensics and Incident Response Platform - IDOR Investigation Case
# ============================================================

# ------------------------------------------------------------
# Agent Runtime
# ------------------------------------------------------------
AGENTS_USE_LLM=true
AGENTS_DRY_RUN=true

HUMAN_APPROVAL_MODE=simulated
# HUMAN_DECISION_SCENARIO=approve # Opções: "approve", "reject", "modify", "request_more_evidence"
HUMAN_DECISION_SCENARIO=approve
# HUMAN_DECISION_SCENARIO=reject
# HUMAN_DECISION_SCENARIO=modify
# HUMAN_DECISION_SCENARIO=request_more_evidence

LANGGRAPH_CHECKPOINT_BACKEND=memory

# ------------------------------------------------------------
# LLM economics quota for question batch runs
# ------------------------------------------------------------
SOC_COPILOT_BENCHMARK_LLM_MAX_QUESTIONS=3

SOC_COPILOT_BENCHMARK_SLEEP_SECONDS=2

# ============================================================
# ACTIVE PROVIDER
# ============================================================
#
# Default provider for local development.
# Fast, cheap and OpenAI-compatible.
#
# Replace only the API key.
# ============================================================
# Providers enabled for free local testing and development. 
#
# For production or more extensive evaluation, switch to a native provider or 
# paid plans with paid model keys.
# ============================================================
# Groq OpenAI-compatible — ACTIVE
# ============================================================
# LLM_PROVIDER=groq
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# Other model options:
# LLM_MODEL=llama-3.1-8b-instant
# LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# LLM_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct
# LLM_MODEL=deepseek-r1-distill-llama-70b
# LLM_MODEL=qwen/qwen3-32b

# ============================================================
# OpenRouter — OpenAI-compatible gateway
# ============================================================
# LLM_PROVIDER=openrouter
# LLM_API_KEY=sk-or-...
# LLM_MODEL=qwen/qwen3-32b
# LLM_MODEL=openai/gpt-4.1-mini
# LLM_BASE_URL=https://openrouter.ai/api/v1

# OpenAI via OpenRouter
# LLM_MODEL=openai/gpt-4.1-mini
# LLM_MODEL=openai/gpt-4o-mini
# LLM_MODEL=openai/gpt-4o

# Anthropic Claude via OpenRouter
# LLM_MODEL=anthropic/claude-sonnet-4
# LLM_MODEL=anthropic/claude-3.5-sonnet
# LLM_MODEL=anthropic/claude-3.5-haiku
# LLM_MODEL=anthropic/claude-3-opus

# Gemini via OpenRouter
# LLM_MODEL=google/gemini-2.5-flash
# LLM_MODEL=google/gemini-2.5-pro

# Meta Llama via OpenRouter
# LLM_MODEL=meta-llama/llama-4-scout
# LLM_MODEL=meta-llama/llama-4-maverick
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct
# LLM_MODEL=meta-llama/llama-3.1-405b-instruct
# LLM_MODEL=meta-llama/llama-3.1-70b-instruct
# LLM_MODEL=meta-llama/llama-3.1-8b-instruct

# DeepSeek via OpenRouter
# LLM_MODEL=deepseek/deepseek-chat
# LLM_MODEL=deepseek/deepseek-r1

# Qwen via OpenRouter
# LLM_MODEL=qwen/qwen3-235b-a22b
# LLM_MODEL=qwen/qwen3-32b
# LLM_MODEL=qwen/qwen-2.5-72b-instruct

# xAI Grok via OpenRouter
# LLM_MODEL=x-ai/grok-3
# LLM_MODEL=x-ai/grok-3-mini

# ============================================================
# Google AI Studio / Gemini Native OpenAI-compatible
# ============================================================
# LLM_PROVIDER=gemini
# LLM_API_KEY=AIza...
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-2.5-flash

# Other Gemini options:
# LLM_MODEL=gemini-2.5-pro

# ============================================================
# Cerebras Native OpenAI-compatible
# ============================================================
# LLM_PROVIDER=cerebras
# LLM_API_KEY=csk-...
# LLM_BASE_URL=https://api.cerebras.ai/v1
# LLM_MODEL=qwen-3-32b

# Other model options:
# LLM_MODEL=llama-3.3-70b
# LLM_MODEL=qwen-3-32b

# ============================================================
# SambaNova Native OpenAI-compatible
# ============================================================
# LLM_PROVIDER=sambanova
# LLM_API_KEY=snv-...
# LLM_BASE_URL=https://api.sambanova.ai/v1
# LLM_MODEL=Meta-Llama-3.3-70B-Instruct

# ============================================================
# Together AI Native OpenAI-compatible
# ============================================================
# LLM_PROVIDER=together
# LLM_API_KEY=...
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Other model options:
# LLM_MODEL=Qwen/Qwen3-32B
# LLM_MODEL=deepseek-ai/DeepSeek-R1

# ============================================================
# Fireworks
# ============================================================
# LLM_PROVIDER=fireworks
# LLM_API_KEY=fw-...
# LLM_BASE_URL=https://api.fireworks.ai/inference/v1
# LLM_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct


# ============================================================
# Providers that require paid plans.
# ============================================================
# OpenAI Native
# ============================================================
# LLM_PROVIDER=openai 
# LLM_API_KEY=sk-proj-...
# LLM_BASE_URL=empty/default OpenAI endpoint
# LLM_MODEL=gpt-4.1-mini
# Other OpenAI options:
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL=gpt-4o
# LLM_MODEL=gpt-4.1
# ============================================================

# Perplexity OpenAI-compatible
# ============================================================
# LLM_PROVIDER=perplexity
# LLM_API_KEY=pplx-...
# LLM_BASE_URL=https://api.perplexity.ai
# LLM_MODEL=sonar-pro

# Other Perplexity options:
# LLM_MODEL=sonar
# LLM_MODEL=sonar-reasoning-pro
# LLM_MODEL=sonar-deep-research

# ============================================================
# xAI Grok Native OpenAI-compatible
# ============================================================
# LLM_PROVIDER=xai
# LLM_API_KEY=xai-...
# LLM_BASE_URL=https://api.x.ai/v1
# LLM_MODEL=grok-3

# Other xAI options:
# LLM_MODEL=grok-3-mini

# ============================================================
# Local OpenAI-compatible server
# LM Studio / Ollama proxy / LiteLLM / vLLM
# ============================================================
# LLM_PROVIDER=local
# LLM_API_KEY=dummy
# LLM_MODEL=local-model-name
# LLM_BASE_URL=http://localhost:1234/v1

# ============================================================
# VECTOR RAG
# ============================================================

VECTOR_STORE_BACKEND=chroma

VECTOR_STORE_DIR=data/vector_store/chroma

VECTOR_STORE_COLLECTION=dfir_investigation_artifacts

VECTOR_COLLECTION_NAME=dfir_investigation_artifacts

EMBEDDING_PROVIDER=hash

EMBEDDING_DIMENSIONS=384

# ------------------------------------------------------------
# Safety note
# ------------------------------------------------------------
# This .env file is local and must never be overwritten by validation scripts.
# Scripts may generate .env.deterministic or .env.example.llm, but should not replace .env.